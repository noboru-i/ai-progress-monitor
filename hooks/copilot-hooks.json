{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh SessionStart",
        "timeout": 5
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh UserPromptSubmit",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh PreToolUse",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh PostToolUse",
        "timeout": 5
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh PreCompact",
        "timeout": 5
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "~/Library/Application Support/AIProgressMonitor/copilot-hook.sh SubagentStart",
